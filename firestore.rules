rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helpers
    function isSignedIn() {
      return true; // request.auth != null; // Temoporarily disabled to allow sync
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Test connection
    match /test/connection {
      allow read, write: if true;
    }

    // Public readable but admin writable
    match /competitions/{id} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /athletics/{id} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /modalities/{id} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /results/{id} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /penalties/{id} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /birthdays/{id} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /config/global {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // Products and Score Rules - Publicly readable
    match /products/{id} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /scoreRules/{id} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /transactions/{id} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /financeCategories/{id} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /socios/{id} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /plannerEvents/{id} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /declaracoes/{id} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /shareMembers/{id} {
      allow read: if true;
      allow create, update: if isSignedIn() && incoming().keys().hasAll(['id', 'name']) && incoming().id == id;
      allow delete: if isSignedIn();
    }

    match /sharePosts/{id} {
      allow read: if true;
      allow create, update: if isSignedIn() && incoming().keys().hasAll(['id', 'title', 'date']) && incoming().id == id;
      allow delete: if isSignedIn();
    }

    match /shareRecords/{id} {
      allow read: if true;
      allow create, update: if isSignedIn() && incoming().keys().hasAll(['id', 'memberId', 'postId', 'shared']) && incoming().id == id;
      allow delete: if isSignedIn();
    }

    // Validation Helpers
    function incoming() {
      return request.resource.data;
    }
  }
}
