rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Public readable but admin writable
    match /competitions/{id} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /athletics/{id} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /modalities/{id} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /results/{id} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /penalties/{id} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /birthdays/{id} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /config/global {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // Products and Score Rules - Publicly readable
    match /products/{id} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /scoreRules/{id} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /shareMembers/{id} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /sharePosts/{id} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /shareRecords/{id} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // Finance and Inventory - more restricted
    match /transactions/{id} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /financeCategories/{id} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /socios/{id} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /plannerEvents/{id} {
      allow read: if true;
      allow create, update: if isSignedIn() && isValidPlannerEvent(incoming());
      allow delete: if isSignedIn();
    }

    match /declaracoes/{id} {
      allow read: if true;
      allow create, update: if isSignedIn() && isValidDeclaration(incoming());
      allow delete: if isSignedIn();
    }

    match /shareMembers/{id} {
      allow read: if true;
      allow create, update: if isSignedIn() && incoming().keys().hasAll(['id', 'name']) && incoming().id == id;
      allow delete: if isSignedIn();
    }

    match /sharePosts/{id} {
      allow read: if true;
      allow create, update: if isSignedIn() && incoming().keys().hasAll(['id', 'title', 'date']) && incoming().id == id;
      allow delete: if isSignedIn();
    }

    match /shareRecords/{id} {
      allow read: if true;
      allow create, update: if isSignedIn() && incoming().keys().hasAll(['id', 'memberId', 'postId', 'shared']) && incoming().id == id;
      allow delete: if isSignedIn();
    }

    // Validation Helpers
    function incoming() {
      return request.resource.data;
    }

    function isValidPlannerEvent(data) {
      return data.keys().hasAll(['id', 'title', 'date', 'type']) &&
             data.id is string && isValidId(data.id) &&
             data.title is string && data.title.size() <= 200 &&
             data.date is string &&
             data.type in ['meeting', 'training', 'event', 'other'];
    }

    function isValidDeclaration(data) {
      return data.keys().hasAll(['id', 'fullName', 'course', 'document', 'issueDate', 'extractedAt']) &&
             data.id is string && isValidId(data.id) &&
             data.fullName is string && data.fullName.size() <= 1000 &&
             data.course is string && data.course.size() <= 1000 &&
             data.document is string && data.document.size() <= 1000 &&
             data.issueDate is string &&
             data.extractedAt is number;
    }
  }
}
