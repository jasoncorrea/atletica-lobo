rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Public readable but admin writable
    match /competitions/{id} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /athletics/{id} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /modalities/{id} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /results/{id} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /penalties/{id} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /birthdays/{id} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /config/global {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // Products and Score Rules - Publicly readable
    match /products/{id} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /scoreRules/{id} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /shareMembers/{id} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /sharePosts/{id} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /shareRecords/{id} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // Finance and Inventory - more restricted
    match /transactions/{id} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /financeCategories/{id} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /socios/{id} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /shareMembers/{id} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /sharePosts/{id} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /shareRecords/{id} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /managementEvents/{id} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }
  }
}
